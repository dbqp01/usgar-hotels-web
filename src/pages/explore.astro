---
import Layout from '../layouts/Layout.astro';
import { attractions } from '../data/attractions';
import { useTranslations } from '../i18n/utils';

const lang = (Astro.currentLocale || 'en') as 'en' | 'es';
const t = useTranslations(lang);

// Unique categories in dataset
const categories = ['all', 'historical', 'nature', 'cultural', 'adventure'];

const categoryLabels: Record<string, { en: string; es: string }> = {
  all: { en: 'All', es: 'Todos' },
  historical: { en: 'Historical', es: 'Histórico' },
  nature: { en: 'Nature', es: 'Naturaleza' },
  cultural: { en: 'Cultural', es: 'Cultural' },
  adventure: { en: 'Adventure', es: 'Aventura' }
};

const categoryIcons: Record<string, string> = {
  all: '🗺️',
  historical: '🏛️',
  nature: '🏔️',
  cultural: '🎭',
  adventure: '🥾'
};

const attractionsSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": lang === 'es' ? 'Atracciones turísticas cerca de USGAR Hotels' : 'Tourist attractions near USGAR Hotels',
  "description": lang === 'es' ? 'Descubre los mejores destinos históricos, culturales y naturales cerca de USGAR Hotels en Cusco.' : 'Discover the best historical, cultural, and natural destinations near USGAR Hotels in Cusco.',
  "itemListElement": attractions.map((attraction, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "TouristAttraction",
      "name": attraction.name[lang],
      "description": attraction.description[lang],
      "distance": attraction.distance,
      "location": {
        "@type": "Place",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Cusco",
          "addressCountry": "PE"
        }
      }
    }
  }))
};
---

<Layout title={`${t('explore.title')} — USGAR Hotels`} lang={lang} schema={attractionsSchema}>
  <!-- Top Banner / Hero -->
  <section class="relative pt-32 pb-20 px-4 bg-gradient-to-b from-primary/10 via-transparent to-transparent overflow-hidden">
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <span class="text-sm font-semibold text-primary uppercase tracking-widest">{t('explore.sectionLabel')}</span>
      <h1 class="font-display text-4xl md:text-6xl mt-2 mb-6 leading-tight text-[#1C1917] dark:text-[#FAFAF9]">
        {t('explore.title')}
      </h1>
      <p class="text-lg md:text-xl text-[#57534E] dark:text-[#A8A29E] max-w-2xl mx-auto font-body font-light leading-relaxed">
        {t('explore.description')}
      </p>
    </div>
  </section>

  <!-- Content Section -->
  <section class="pb-24 px-4 max-w-7xl mx-auto">
    
    <!-- Controls (Search + Filters) -->
    <div class="mb-12 flex flex-col md:flex-row gap-6 items-center justify-between bg-white dark:bg-[#1C1917] border border-black/5 dark:border-white/5 p-6 rounded-3xl shadow-sm">
      
      <!-- Category Filters -->
      <div class="flex gap-2 overflow-x-auto w-full md:w-auto pb-2 md:pb-0 scrollbar-hide snap-x snap-mandatory">
        {categories.map((cat) => (
          <button
            class="flex items-center gap-2 px-4 py-2 rounded-full border text-sm font-medium transition-all duration-300 cursor-pointer whitespace-nowrap snap-center select-none bg-stone-50 dark:bg-stone-900/40 border-stone-200 dark:border-stone-800 text-stone-600 dark:text-stone-400 hover:border-primary/50 dark:hover:border-primary/50 hover:text-primary hover:scale-[1.02]"
            data-category-filter={cat}
          >
            <span>{categoryIcons[cat]}</span>
            <span>{categoryLabels[cat][lang]}</span>
          </button>
        ))}
      </div>

      <!-- Search Bar -->
      <div class="relative w-full md:w-80">
        <span class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-stone-400">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </span>
        <input
          type="text"
          id="explore-search"
          placeholder={lang === 'es' ? 'Buscar atracción...' : 'Search attraction...'}
          class="w-full pl-10 pr-4 py-2.5 rounded-full border border-stone-200 dark:border-stone-800 bg-stone-50 dark:bg-stone-900/40 text-stone-800 dark:text-stone-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all placeholder:text-stone-400"
          aria-label="Search attractions"
        />
      </div>
    </div>

    <!-- Attractions Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8" id="attractions-grid">
      {attractions.map((attraction, i) => (
        <div
          class="p-6 rounded-2xl bg-white dark:bg-[#1C1917] border border-black/5 dark:border-white/5 shadow-sm hover:shadow-lg transition-all duration-500 hover:-translate-y-1 group flex flex-col justify-between"
          data-category={attraction.category}
          data-name-en={attraction.name.en.toLowerCase()}
          data-name-es={attraction.name.es.toLowerCase()}
          data-desc-en={attraction.description.en.toLowerCase()}
          data-desc-es={attraction.description.es.toLowerCase()}
          style={`transition-delay: ${i * 0.05}s`}
        >
          <div>
            <!-- Top badge row -->
            <div class="flex items-center justify-between mb-4">
              <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider bg-tertiary/10 text-tertiary">
                <span class="text-sm">{categoryIcons[attraction.category]}</span>
                <span>{categoryLabels[attraction.category][lang]}</span>
              </span>
              <span class="text-xs font-medium text-stone-500 dark:text-stone-400 bg-stone-100 dark:bg-stone-900 px-2.5 py-1 rounded-md">
                📍 {attraction.distance}
              </span>
            </div>

            <!-- Title & Desc -->
            <h3 class="font-display text-xl mb-3 text-[#1C1917] dark:text-[#FAFAF9] group-hover:text-primary transition-colors duration-300">
              {attraction.name[lang]}
            </h3>
            <p class="text-sm md:text-base text-[#57534E] dark:text-[#A8A29E] font-body leading-relaxed mb-6">
              {attraction.description[lang]}
            </p>
          </div>

          <!-- Bottom Time Row -->
          <div class="pt-4 border-t border-black/5 dark:border-white/5 flex items-center justify-between text-xs text-[#A8A29E] font-body">
            <span class="flex items-center gap-1 font-medium">
              ⏱️ {attraction.travelTime}
            </span>
            <a
              href={`https://maps.google.com/?q=${encodeURIComponent(attraction.name[lang] + ', Cusco')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-primary hover:text-primary-dark font-semibold inline-flex items-center gap-1 group/link"
            >
              {lang === 'es' ? 'Cómo llegar' : 'Directions'}
              <svg class="w-3.5 h-3.5 group-hover/link:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Empty State -->
    <div id="explore-empty-state" class="hidden text-center py-20 bg-white dark:bg-[#1C1917] border border-black/5 dark:border-white/5 p-8 rounded-3xl mt-6">
      <span class="text-5xl block mb-4">🔍</span>
      <h3 class="font-display text-2xl mb-2 text-[#1C1917] dark:text-[#FAFAF9]">
        {lang === 'es' ? 'No se encontraron atracciones' : 'No attractions found'}
      </h3>
      <p class="text-[#57534E] dark:text-[#A8A29E] font-body max-w-sm mx-auto">
        {lang === 'es' ? 'Prueba cambiando los filtros o la palabra de búsqueda.' : 'Try adjusting your filters or search keywords.'}
      </p>
    </div>
  </section>
</Layout>

<script>
  function initExploreFilters() {
    const searchInput = document.getElementById('explore-search') as HTMLInputElement;
    const filterButtons = document.querySelectorAll('[data-category-filter]');
    const grid = document.getElementById('attractions-grid');
    const emptyState = document.getElementById('explore-empty-state');
    
    if (!grid || !emptyState) return;

    const cards = Array.from(grid.children) as HTMLElement[];
    const isEs = document.documentElement.lang === 'es';

    let activeFilter = 'all';
    let searchQuery = '';

    // Set 'all' filter as active initially
    filterButtons.forEach(btn => {
      const cat = btn.getAttribute('data-category-filter');
      if (cat === 'all') {
        btn.classList.add('border-primary', 'text-primary', 'bg-primary/5');
        btn.classList.remove('border-stone-200', 'dark:border-stone-800', 'text-stone-600', 'dark:text-stone-400');
      }
    });

    function applyFilter() {
      let visibleCount = 0;

      cards.forEach(card => {
        const category = card.getAttribute('data-category');
        const nameAttr = isEs ? 'data-name-es' : 'data-name-en';
        const descAttr = isEs ? 'data-desc-es' : 'data-desc-en';
        const name = card.getAttribute(nameAttr) || '';
        const desc = card.getAttribute(descAttr) || '';

        const matchesCategory = activeFilter === 'all' || category === activeFilter;
        const matchesSearch = name.includes(searchQuery) || desc.includes(searchQuery);

        if (matchesCategory && matchesSearch) {
          card.classList.remove('hidden');
          // Add entrance animation class
          card.classList.add('animate-fade-in');
          visibleCount++;
        } else {
          card.classList.add('hidden');
          card.classList.remove('animate-fade-in');
        }
      });

      // Show/hide empty state
      if (visibleCount === 0) {
        emptyState.classList.remove('hidden');
        grid.classList.add('hidden');
      } else {
        emptyState.classList.add('hidden');
        grid.classList.remove('hidden');
      }
    }

    // Category button click
    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.getAttribute('data-category-filter') || 'all';
        activeFilter = cat;

        // Toggle button styling
        filterButtons.forEach(b => {
          if (b === btn) {
            b.classList.add('border-primary', 'text-primary', 'bg-primary/5');
            b.classList.remove('border-stone-200', 'dark:border-stone-800', 'text-stone-600', 'dark:text-stone-400');
          } else {
            b.classList.remove('border-primary', 'text-primary', 'bg-primary/5');
            b.classList.add('border-stone-200', 'dark:border-stone-800', 'text-stone-600', 'dark:text-stone-400');
          }
        });

        applyFilter();
      });
    });

    // Search input typing
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
        applyFilter();
      });
    }
  }

  // Init filter scripts
  initExploreFilters();

  // Re-run after page swap
  document.addEventListener('astro:after-swap', initExploreFilters);
</script>
