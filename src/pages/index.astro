---
import Layout from '../layouts/Layout.astro';
import BookingWidget from '../components/BookingWidget.astro';
import RoomCard from '../components/RoomCard.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import FAQSection from '../components/FAQSection.astro';
import MapSection from '../components/MapSection.astro';
import { rooms } from '../data/rooms';
import { attractions } from '../data/attractions';
import { faqs } from '../data/faq';
import { useTranslations } from '../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { Image, getImage } from 'astro:assets';

// Hotel slideshow slides
import slide1 from '../assets/hotel/_DSC3824.jpg';
import slide2 from '../assets/hotel/_DSC3825.jpg';
import slide3 from '../assets/hotel/_DSC3827.jpg';
import slide4 from '../assets/hotel/_DSC3828.jpg';

const lang = (Astro.currentLocale || 'en') as 'en' | 'es';
const optimizedPoster = await getImage({ src: slide1, width: 1200, format: 'webp' });
const t = useTranslations(lang);

const reviews = [
  {
    name: 'Sarah M.',
    country: '🇺🇸',
    text: {
      en: 'Absolutely magical! The murals and Andean decor made us feel immersed in local culture. Breakfast was incredible and the staff went above and beyond.',
      es: '¡Absolutamente mágico! Los murales y la decoración andina nos hicieron sentir sumergidos en la cultura local. El desayuno fue increíble y el personal fue excepcional.'
    }
  },
  {
    name: 'Thomas K.',
    country: '🇩🇪',
    text: {
      en: 'Perfect location near San Pedro Market. The rooms are warm and cozy — essential for cold Cusco nights. Will definitely return!',
      es: 'Ubicación perfecta cerca del Mercado de San Pedro. Las habitaciones son cálidas y acogedoras, algo esencial para las frías noches de Cusco. ¡Definitivamente volveré!'
    }
  },
  {
    name: 'Ana L.',
    country: '🇧🇷',
    text: {
      en: 'The airport transfer service was a lifesaver. Hotel is charming, clean, and the staff speaks English fluently. Great value for money.',
      es: 'El servicio de traslado al aeropuerto fue un salvavidas. El hotel es encantador, limpio y el personal habla inglés con fluidez. Gran relación calidad-precio.'
    }
  },
  {
    name: 'James P.',
    country: '🇬🇧',
    text: {
      en: 'Lovely boutique hotel with character. The spa massage after a long day of hiking was exactly what we needed. Highly recommended!',
      es: 'Hermoso hotel boutique con carácter. El masaje de spa después de un largo día de caminata fue exactamente lo que necesitábamos. ¡Altamente recomendado!'
    }
  },
  {
    name: 'Yuki T.',
    country: '🇯🇵',
    text: {
      en: 'Beautiful hotel with authentic Cusco charm. They helped us arrange our Machu Picchu tour and it was seamless. The breakfast is fresh and delicious.',
      es: 'Hermoso hotel con encanto auténtico de Cusco. Nos ayudaron a organizar nuestro tour a Machu Picchu y todo fue perfecto. El desayuno es fresco y delicioso.'
    }
  },
  {
    name: 'Elena R.',
    country: '🇪🇸',
    text: {
      en: 'A beautiful hidden gem in Cusco. Excellent service, hot water 24h, and heaters that work perfectly. Super close to the historic market.',
      es: 'Una hermosa joya escondida en Cusco. Excelente servicio, agua caliente las 24 horas y calefacción que funciona a la perfección. Muy cerca del mercado histórico.'
    }
  },
  {
    name: 'Mark B.',
    country: '🇨🇦',
    text: {
      en: 'Very clean rooms, comfortable beds, and a delicious breakfast buffet. The staff helped us book a safe taxi from the airport. Highly recommended!',
      es: 'Habitaciones muy limpias, camas cómodas y un delicioso desayuno buffet. El personal nos ayudó a reservar un taxi seguro desde el aeropuerto. ¡Muy recomendado!'
    }
  },
  {
    name: 'Sophie D.',
    country: '🇫🇷',
    text: {
      en: 'Outstanding boutique hotel! Hand-painted murals in the room are stunning. Having heaters was amazing for cold nights. 10/10 experience!',
      es: '¡Destacado hotel boutique! Los murales pintados a mano en la habitación son impresionantes. Tener calefacción fue increíble para las noches frías. ¡Experiencia 10/10!'
    }
  }
];

const hotelSchema = {
  "@context": "https://schema.org",
  "@type": "Hotel",
  "name": "USGAR Hotels",
  "description": lang === 'es' 
    ? 'USGAR Hotels es un hotel boutique en San Pedro, Cusco, cerca del Mercado de San Pedro. Habitaciones con murales andinos y desayuno buffet.' 
    : 'USGAR Hotels is a boutique hotel in San Pedro, Cusco, near the San Pedro Market. Rooms with hand-painted Andean murals.',
  "image": "https://usgarhotels.com/assets/logos/Logo%20usgar%20morado.png",
  "telephone": "+51984000000",
  "email": "info@usgarhotels.com",
  "url": "https://usgarhotels.com" + (lang === 'es' ? '/es' : ''),
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "San Pedro",
    "addressLocality": "Cusco",
    "addressRegion": "Cusco",
    "postalCode": "08002",
    "addressCountry": "PE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -13.5226,
    "longitude": -71.9828
  },
  "starRating": {
    "@type": "Rating",
    "ratingValue": "3"
  },
  "priceRange": "$$"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question[lang],
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer[lang]
    }
  }))
};

const schemas = [hotelSchema, faqSchema];
---

<Layout title={`${t('hero.title')} — Boutique Hotel in San Pedro, Cusco`} lang={lang} schema={schemas}>

  <!-- ==========================================
       HERO SECTION — Video Background
       ========================================== -->
  <section class="relative h-screen min-h-[600px] flex items-center justify-center overflow-hidden" id="hero">
    <!-- Video Background (No loop attribute, transition opacity) -->
    <video
      autoplay
      muted
      playsinline
      class="absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 z-0"
      poster={optimizedPoster.src}
      id="hero-video"
    >
      <source src="/videos/100ANV26.mp4" type="video/mp4" />
    </video>

    <!-- Slideshow Background (Initially hidden) -->
    <div id="hero-slideshow" class="absolute inset-0 w-full h-full opacity-0 pointer-events-none transition-opacity duration-1000 z-0">
      <div class="absolute inset-0 transition-opacity duration-1000 opacity-0" data-slide="0">
        <Image src={slide1} alt="USGAR Hotels Cusco" class="w-full h-full object-cover" />
      </div>
      <div class="absolute inset-0 transition-opacity duration-1000 opacity-0" data-slide="1">
        <Image src={slide2} alt="USGAR Hotels Cusco Rooms" class="w-full h-full object-cover" />
      </div>
      <div class="absolute inset-0 transition-opacity duration-1000 opacity-0" data-slide="2">
        <Image src={slide3} alt="USGAR Hotels Cusco Entrance" class="w-full h-full object-cover" />
      </div>
      <div class="absolute inset-0 transition-opacity duration-1000 opacity-0" data-slide="3">
        <Image src={slide4} alt="USGAR Hotels Cusco Murals" class="w-full h-full object-cover" />
      </div>
    </div>

    <!-- Dark Overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/30 to-black/60"></div>

    <!-- Content -->
    <div class="relative z-10 text-center text-white px-4 max-w-4xl mx-auto">
      <h1 class="font-display text-5xl md:text-7xl lg:text-8xl mb-6 drop-shadow-lg animate-fade-in">
        {t('hero.title')}
      </h1>
      <p class="text-lg md:text-2xl font-light tracking-wide opacity-90 mb-8 animate-slide-up" style="animation-delay: 0.3s; animation-fill-mode: both;">
        {t('hero.subtitle')}
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 0.6s; animation-fill-mode: both;">
        <a
          href={getRelativeLocaleUrl(lang, 'book')}
          class="bg-primary hover:bg-primary-dark text-white font-semibold px-8 py-3.5 rounded-full transition-all duration-300 hover:shadow-lg hover:shadow-primary/30 hover:-translate-y-0.5 text-lg"
        >
          {t('hero.cta')}
        </a>
        <a
          href="#rooms"
          class="border border-white/40 hover:border-white/80 text-white px-8 py-3.5 rounded-full transition-all duration-300 hover:bg-white/10 text-lg"
        >
          {t('hero.ctaSecondary')}
        </a>
      </div>
    </div>

    <!-- Video Audio Toggle -->
    <button
      id="video-audio-toggle"
      class="absolute bottom-28 right-6 z-10 w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center hover:bg-white/30 transition-all duration-300"
      aria-label="Toggle video audio"
    >
      <!-- Muted icon -->
      <svg id="muted-icon" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2" />
      </svg>
      <!-- Unmuted icon (hidden by default) -->
      <svg id="unmuted-icon" class="w-5 h-5 text-white hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
      </svg>
    </button>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
      <svg class="w-6 h-6 text-white/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- ==========================================
       BOOKING WIDGET
       ========================================== -->
  <BookingWidget />

  <!-- ==========================================
       TRUST MARQUEE — Positive Reviews Ribbon
       ========================================== -->
  <section class="pb-16 -mt-4 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 mb-4 text-center">
      <span class="text-xs font-semibold text-primary uppercase tracking-widest">{t('reviews.sectionLabel')}</span>
    </div>
    <div class="marquee-container">
      <div class="marquee-content">
        {reviews.map(review => (
          <div class="flex-shrink-0 w-80 bg-white dark:bg-[#1C1917] p-5 rounded-2xl border border-black/5 dark:border-white/5 shadow-sm space-y-3">
            <div class="flex items-center justify-between">
              <span class="text-xs text-secondary font-semibold">⭐⭐⭐⭐⭐</span>
              <span class="text-xs text-[#A8A29E]">{review.country} {review.name}</span>
            </div>
            <p class="text-xs text-[#57534E] dark:text-[#A8A29E] italic leading-relaxed">
              "{review.text[lang]}"
            </p>
          </div>
        ))}
      </div>
      <!-- Duplicate for seamless scroll -->
      <div class="marquee-content" aria-hidden="true">
        {reviews.map(review => (
          <div class="flex-shrink-0 w-80 bg-white dark:bg-[#1C1917] p-5 rounded-2xl border border-black/5 dark:border-white/5 shadow-sm space-y-3">
            <div class="flex items-center justify-between">
              <span class="text-xs text-secondary font-semibold">⭐⭐⭐⭐⭐</span>
              <span class="text-xs text-[#A8A29E]">{review.country} {review.name}</span>
            </div>
            <p class="text-xs text-[#57534E] dark:text-[#A8A29E] italic leading-relaxed">
              "{review.text[lang]}"
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==========================================
       ROOMS SECTION
       ========================================== -->
  <section id="rooms" class="py-20 px-4">
    <div class="max-w-7xl mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-14 animate-on-scroll">
        <span class="text-sm font-semibold text-primary uppercase tracking-widest">{t('rooms.sectionLabel')}</span>
        <h2 class="font-display text-4xl md:text-5xl mt-3 mb-4">
          {t('rooms.title')}
        </h2>
        <p class="text-lg text-[#57534E] dark:text-[#A8A29E] max-w-2xl mx-auto">
          {t('rooms.description')}
        </p>
      </div>

      <!-- Rooms Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {rooms.map((room, i) => (
          <RoomCard room={room} index={i} />
        ))}
      </div>
    </div>
  </section>

  <!-- ==========================================
       SERVICES SECTION
       ========================================== -->
  <ServiceGrid />


  <!-- ==========================================
       EXPLORE CUSCO PREVIEW
       ========================================== -->
  <section class="py-20 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-14 animate-on-scroll">
        <span class="text-sm font-semibold text-primary uppercase tracking-widest">{t('explore.sectionLabel')}</span>
        <h2 class="font-display text-4xl md:text-5xl mt-3 mb-4">
          {t('explore.title')}
        </h2>
        <p class="text-lg text-[#57534E] dark:text-[#A8A29E] max-w-2xl mx-auto">
          {t('explore.description')}
        </p>
      </div>

      <!-- Attractions Preview (first 4) -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {attractions.slice(0, 4).map((attraction, i) => (
          <div
            class="animate-on-scroll stagger-child p-6 rounded-2xl bg-white dark:bg-[#1C1917] border border-black/5 dark:border-white/5 hover:border-tertiary/20 hover:shadow-lg transition-all duration-300 group"
            style={`transition-delay: ${i * 0.1}s`}
          >
            <div class="flex items-start justify-between mb-3">
              <span class="text-xs font-semibold uppercase tracking-wider text-tertiary">
                {attraction.category}
              </span>
              <span class="text-xs text-[#A8A29E]">
                {attraction.distance}
              </span>
            </div>
            <h3 class="font-display text-lg mb-2 group-hover:text-tertiary transition-colors">
              {attraction.name[lang]}
            </h3>
            <p class="text-sm text-[#57534E] dark:text-[#A8A29E] line-clamp-2 mb-3">
              {attraction.description[lang]}
            </p>
            <span class="text-xs text-[#A8A29E]">
              ⏱️ {attraction.travelTime}
            </span>
          </div>
        ))}
      </div>

      <!-- View All Link -->
      <div class="text-center mt-10 animate-on-scroll">
        <a
          href={getRelativeLocaleUrl(lang, 'explore')}
          class="inline-flex items-center gap-2 text-primary hover:text-primary-dark font-semibold transition-colors duration-300 group"
        >
          {t('explore.viewAll')}
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ==========================================
       FAQ SECTION
       ========================================== -->
  <FAQSection />

  <!-- ==========================================
       MAP SECTION
       ========================================== -->
  <MapSection />

</Layout>

<!-- Hero Video Audio Toggle & Slideshow loop -->
<script>
  function initHeroVideo() {
    const video = document.getElementById('hero-video') as HTMLVideoElement;
    const toggleBtn = document.getElementById('video-audio-toggle') as HTMLElement;
    const mutedIcon = document.getElementById('muted-icon') as HTMLElement;
    const unmutedIcon = document.getElementById('unmuted-icon') as HTMLElement;
    const slideshow = document.getElementById('hero-slideshow') as HTMLElement;

    if (!video || !toggleBtn || !mutedIcon || !unmutedIcon || !slideshow) return;

    // Toggle sound
    toggleBtn.addEventListener('click', () => {
      video.muted = !video.muted;
      mutedIcon.classList.toggle('hidden', !video.muted);
      unmutedIcon.classList.toggle('hidden', video.muted);
    });

    const slides = slideshow.querySelectorAll('[data-slide]');
    let currentSlide = 0;
    let slideshowInterval: any = null;

    function startSlideshow() {
      // Fade in slideshow container
      slideshow.classList.remove('opacity-0');
      slideshow.classList.add('opacity-100');
      
      // Hide audio toggle button during slideshow
      toggleBtn.classList.add('opacity-0', 'pointer-events-none');

      // Show first slide
      currentSlide = 0;
      slides[currentSlide].classList.remove('opacity-0');
      slides[currentSlide].classList.add('opacity-100');

      slideshowInterval = setInterval(() => {
        // Fade out current slide
        slides[currentSlide].classList.remove('opacity-100');
        slides[currentSlide].classList.add('opacity-0');

        currentSlide++;

        if (currentSlide < slides.length) {
          // Fade in next slide
          slides[currentSlide].classList.remove('opacity-0');
          slides[currentSlide].classList.add('opacity-100');
        } else {
          // End of slideshow: clean up and return to video
          clearInterval(slideshowInterval);
          
          // Fade out slideshow container
          slideshow.classList.remove('opacity-100');
          slideshow.classList.add('opacity-0');

          // Reset all slides to opacity-0
          slides.forEach(slide => {
            slide.classList.remove('opacity-100');
            slide.classList.add('opacity-0');
          });

          // Fade in video
          video.classList.remove('opacity-0');
          video.classList.add('opacity-100');

          // Fade in audio toggle
          toggleBtn.classList.remove('opacity-0', 'pointer-events-none');

          // Replay video
          video.currentTime = 0;
          video.play().catch(err => console.log('Replay error:', err));
        }
      }, 4000);
    }

    // When video ends
    video.addEventListener('ended', () => {
      // Fade out video
      video.classList.remove('opacity-100');
      video.classList.add('opacity-0');

      // Start slideshow
      startSlideshow();
    });

    // Cleanup interval on page transition
    document.addEventListener('astro:before-swap', () => {
      if (slideshowInterval) clearInterval(slideshowInterval);
    }, { once: true });
  }

  // Init on load
  initHeroVideo();
  
  // Re-init after Astro View Transitions page swap
  document.addEventListener('astro:after-swap', initHeroVideo);
</script>
