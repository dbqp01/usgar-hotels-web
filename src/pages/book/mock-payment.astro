---
import Layout from '../../layouts/Layout.astro';

export const prerender = false;

const lang = (Astro.currentLocale || 'en') as 'en' | 'es';

// Get checkout details from URL
const url = new URL(Astro.url);
const bookingId = url.searchParams.get('bookingId') || '';
const roomName = url.searchParams.get('roomName') || 'Room Reservation';
const amount = url.searchParams.get('amount') || '0';
const guestName = url.searchParams.get('guestName') || '';
const guestEmail = url.searchParams.get('guestEmail') || '';
const checkIn = url.searchParams.get('checkIn') || '';
const checkOut = url.searchParams.get('checkOut') || '';
---

<Layout title={`${lang === 'es' ? 'Simulador de Pago — Mercado Pago' : 'Payment Simulator — Mercado Pago'} — USGAR Hotels`} lang={lang}>
  <main class="py-24 px-4 max-w-2xl mx-auto flex-1 flex flex-col justify-center">
    
    <!-- Glassmorphic MP Simulation Card -->
    <div class="bg-white dark:bg-[#1C1917] rounded-3xl border border-black/5 dark:border-white/5 shadow-2xl overflow-hidden animate-slide-up">
      
      <!-- Mercado Pago Header (Blue Header simulation) -->
      <div class="bg-[#009EE3] p-6 text-white flex items-center justify-between">
        <div class="flex items-center gap-3">
          <!-- Handshake logo or text simulation -->
          <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center text-[#009EE3] font-bold text-lg">
            mp
          </div>
          <div>
            <h1 class="font-sans font-semibold text-lg tracking-wide">Mercado Pago</h1>
            <p class="text-xs text-white/80">{lang === 'es' ? 'Entorno Sandbox (Simulador)' : 'Sandbox Environment (Simulator)'}</p>
          </div>
        </div>
        <div class="text-right">
          <span class="text-xs uppercase tracking-wider text-white/70">{lang === 'es' ? 'Total a Pagar' : 'Total to Pay'}</span>
          <p class="font-sans font-bold text-2xl">${amount} USD</p>
        </div>
      </div>

      <!-- Content Panel -->
      <div class="p-8 space-y-6">
        
        <!-- Summary Box -->
        <div class="bg-stone-50 dark:bg-stone-900/50 p-5 rounded-2xl border border-black/5 dark:border-white/5 space-y-3">
          <h2 class="font-display text-xl text-primary font-semibold">{lang === 'es' ? 'Detalles de la Compra' : 'Purchase Details'}</h2>
          
          <div class="grid grid-cols-2 gap-y-2 text-sm">
            <span class="text-[#57534E] dark:text-[#A8A29E]">{lang === 'es' ? 'Establecimiento' : 'Merchant'}</span>
            <span class="font-semibold text-right">USGAR Hotels</span>

            <span class="text-[#57534E] dark:text-[#A8A29E]">{lang === 'es' ? 'Concepto' : 'Product'}</span>
            <span class="font-semibold text-right text-stone-700 dark:text-stone-300">{roomName}</span>

            <span class="text-[#57534E] dark:text-[#A8A29E]">{lang === 'es' ? 'Código Reserva' : 'Booking ID'}</span>
            <span class="font-mono text-xs font-semibold text-right bg-stone-100 dark:bg-stone-800 px-2 py-0.5 rounded text-[#9B6CB5]">{bookingId}</span>

            <span class="text-[#57534E] dark:text-[#A8A29E]">{lang === 'es' ? 'Huésped' : 'Guest'}</span>
            <span class="font-semibold text-right">{guestName} ({guestEmail})</span>

            {checkIn && checkOut && (
              <>
                <span class="text-[#57534E] dark:text-[#A8A29E]">{lang === 'es' ? 'Fechas' : 'Dates'}</span>
                <span class="font-semibold text-right text-xs">{checkIn} &rarr; {checkOut}</span>
              </>
            )}
          </div>
        </div>

        <!-- Simulation Warning -->
        <div class="p-4 rounded-xl bg-[#F5B731]/10 dark:bg-[#F5B731]/15 border border-[#F5B731]/20 text-[#D99E1B] dark:text-secondary flex items-start gap-3">
          <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <div class="text-xs leading-relaxed space-y-1">
            <p class="font-bold">{lang === 'es' ? 'Modo de Prueba Activado' : 'Demo Test Mode Active'}</p>
            <p>
              {lang === 'es' 
                ? 'Esta es una simulación segura. No se realizará ningún cargo real a ninguna tarjeta de crédito.' 
                : 'This is a secure simulation. No real money will be charged to any credit card.'}
            </p>
          </div>
        </div>

        <!-- Simulated Card Details -->
        <div class="space-y-4 border-t border-black/5 dark:border-white/5 pt-5">
          <h3 class="font-display text-lg">{lang === 'es' ? 'Simular Pago con Tarjeta' : 'Simulate Card Payment'}</h3>
          <div class="p-4 rounded-xl border border-black/10 dark:border-white/10 bg-white dark:bg-[#0C0A09] flex items-center justify-between">
            <div class="flex items-center gap-3">
              <!-- Credit Card Icon -->
              <span class="text-2xl">💳</span>
              <div>
                <p class="font-mono text-sm font-semibold">Visa **** 4321</p>
                <p class="text-[10px] text-[#57534E] dark:text-[#A8A29E]">Expiración 12/30 • CVV ***</p>
              </div>
            </div>
            <span class="text-xs uppercase font-bold tracking-wider text-green-600 dark:text-green-400 bg-green-500/10 px-2 py-1 rounded">
              {lang === 'es' ? 'Listo' : 'Ready'}
            </span>
          </div>
        </div>

        <!-- Buttons -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 border-t border-black/5 dark:border-white/5 pt-6">
          <!-- Decline Button -->
          <button
            type="button"
            id="btn-decline"
            class="w-full bg-stone-100 hover:bg-stone-200 dark:bg-stone-800 dark:hover:bg-stone-700 text-stone-800 dark:text-stone-200 font-semibold py-3.5 px-6 rounded-xl transition-all duration-200 text-sm text-center cursor-pointer order-2 md:order-1"
          >
            {lang === 'es' ? 'Rechazar Pago' : 'Decline Payment'}
          </button>

          <!-- Approve Button -->
          <button
            type="button"
            id="btn-approve"
            class="w-full bg-[#009EE3] hover:bg-[#0087c2] text-white font-semibold py-3.5 px-6 rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-[#009EE3]/25 hover:-translate-y-0.5 text-sm flex items-center justify-center gap-2 cursor-pointer order-1 md:order-2"
          >
            <span id="approve-text">{lang === 'es' ? 'Aprobar Pago Exitoso' : 'Approve Payment Success'}</span>
            <!-- Spinner -->
            <svg id="approve-spinner" class="hidden animate-spin h-5 w-5 text-white" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </button>
        </div>

      </div>
    </div>
  </main>
</Layout>

<script define:vars={{ bookingId, amount, lang }}>
  function initMockPayment() {
    const btnApprove = document.getElementById('btn-approve');
    const btnDecline = document.getElementById('btn-decline');
    const approveText = document.getElementById('approve-text');
    const approveSpinner = document.getElementById('approve-spinner');

    btnApprove?.addEventListener('click', async () => {
      // Show loading spinner
      approveSpinner?.classList.remove('hidden');
      if (approveText) approveText.textContent = lang === 'es' ? 'Pagando...' : 'Paying...';
      if (btnApprove) (btnApprove).disabled = true;
      if (btnDecline) (btnDecline).disabled = true;

      try {
        // Trigger Mercado Pago Webhook post request on background to confirm reservation
        const response = await fetch(`/api/webhook-mercado-pago?bookingId=${bookingId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            status: 'approved',
            bookingId: bookingId,
            action: 'payment.created',
            data: { id: 'MOCK-PAY-' + Date.now() }
          }),
        });

        if (!response.ok) throw new Error('Webhook process failed');

        // Redirect to success page on success
        const successPath = lang === 'es' ? `/es/book/success` : `/book/success`;
        window.location.href = `${successPath}?bookingId=${bookingId}`;
      } catch (err) {
        console.error('Simulation error:', err);
        alert(lang === 'es' ? 'Error al simular el pago.' : 'Error simulating payment.');
        
        // Reset buttons
        approveSpinner?.classList.add('hidden');
        if (approveText) approveText.textContent = lang === 'es' ? 'Aprobar Pago Exitoso' : 'Approve Payment Success';
        if (btnApprove) (btnApprove).disabled = false;
        if (btnDecline) (btnDecline).disabled = false;
      }
    });

    btnDecline?.addEventListener('click', () => {
      // Redirect back to checkout page with error
      const bookPath = lang === 'es' ? `/es/book` : `/book`;
      window.location.href = `${bookPath}?error=payment_declined&bookingId=${bookingId}`;
    });
  }

  // Initial and client-router swaps
  initMockPayment();
  document.addEventListener('astro:after-swap', initMockPayment);
</script>
