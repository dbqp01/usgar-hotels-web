---
import Layout from '../../layouts/Layout.astro';
import { rooms } from '../../data/rooms';
import { getBackendBookingStatus, ROOM_ID_TO_SLUG, BACKEND_URL } from '../../services/api';

export const prerender = false;

const lang = (Astro.currentLocale || 'en') as 'en' | 'es';

const url = new URL(Astro.url);
const bookingId = url.searchParams.get('bookingId') || url.searchParams.get('cart_id') || '';

let booking = null;
let room = null;
let errorMsg = null;

if (bookingId) {
  try {
    const statusRes = await getBackendBookingStatus(bookingId);
    if (statusRes && statusRes.success) {
      const roomSlug = ROOM_ID_TO_SLUG[statusRes.id_room_type] || 'matrimonial';
      const resolvedRoom = rooms.find(r => r.slug === roomSlug);
      
      booking = {
        id: statusRes.cart_id,
        guestName: statusRes.guest_name,
        guestEmail: statusRes.guest_email,
        guestPhone: statusRes.guest_phone,
        checkIn: statusRes.checkin,
        checkOut: statusRes.checkout,
        nights: statusRes.nights,
        guests: 2, // default guests
        totalPrice: statusRes.price,
        confirmationCode: 'USG-' + statusRes.cart_id.split('-').pop()?.toUpperCase(),
        status: statusRes.status,
      };
      
      room = {
        name: resolvedRoom ? resolvedRoom.name : { en: statusRes.room_name, es: statusRes.room_name },
        pricePerNight: statusRes.price_per_night,
        photoFolder: resolvedRoom?.photoFolder || 'matrimonial',
      };
    }
  } catch (err: any) {
    console.error('Error fetching booking status:', err);
    errorMsg = err.message;
  }
}

// Format dates nicely
const formatDate = (dateStr: string) => {
  if (!dateStr) return '';
  const d = new Date(dateStr + 'T00:00:00');
  const options: Intl.DateTimeFormatOptions = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
  return d.toLocaleDateString(lang === 'es' ? 'es-PE' : 'en-US', options);
};
---

<Layout title={`${lang === 'es' ? 'Estado de Reserva' : 'Booking Status'} — USGAR Hotels`} lang={lang}>
  <main class="py-24 px-4 max-w-3xl mx-auto flex-1 print:py-10">
    
    {booking && room ? (
      <div class="space-y-8 animate-fade-in">
        
        {booking.status === 'paid' ? (
          <!-- Confirmed/Paid State -->
          <div class="bg-surface-card-light dark:bg-surface-card-dark p-8 rounded-3xl border border-black/5 dark:border-white/5 shadow-2xl text-center space-y-4 print:shadow-none print:border-none print:p-0">
            <!-- Animated success check icon -->
            <div class="mx-auto w-20 h-20 rounded-full bg-green-500/10 dark:bg-green-500/15 text-green-500 flex items-center justify-center border border-green-500/20 shadow-inner print:w-12 print:h-12">
              <svg class="w-10 h-10 print:w-6 print:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>

            <div>
              <span class="text-xs font-semibold text-green-600 dark:text-green-400 uppercase tracking-widest">
                {lang === 'es' ? 'Pago Aprobado con Éxito' : 'Payment Approved Successfully'}
              </span>
              <h1 class="font-display text-4xl md:text-5xl mt-2 mb-3">
                {lang === 'es' ? '¡Tu Reserva está Confirmada!' : 'Reservation Confirmed!'}
              </h1>
              <p class="text-text-secondary-light dark:text-text-secondary-dark text-sm max-w-md mx-auto print:text-xs">
                {lang === 'es' 
                  ? '¡Gracias por elegir USGAR Hotels! Hemos enviado los detalles de tu estadía y tu confirmación de pago por email.' 
                  : 'Thank you for choosing USGAR Hotels! We have emailed your stay details and payment receipt.'}
              </p>
            </div>

            <!-- Highlighted Confirmation Code -->
            <div class="inline-block bg-stone-50 dark:bg-stone-900 border border-black/5 dark:border-white/5 px-6 py-4 rounded-2xl print:bg-stone-100">
              <span class="block text-[10px] uppercase tracking-widest text-text-secondary-light dark:text-text-secondary-dark">
                {lang === 'es' ? 'Código de Confirmación' : 'Confirmation Code'}
              </span>
              <span class="font-mono text-xl md:text-2xl font-bold text-primary select-all">
                {booking.confirmationCode}
              </span>
            </div>
          </div>
        ) : booking.status === 'pending' ? (
          <!-- Pending Payment / Webhook Polling State -->
          <div class="bg-surface-card-light dark:bg-surface-card-dark p-8 rounded-3xl border border-black/5 dark:border-white/5 shadow-2xl text-center space-y-6">
            <!-- Loading spinner -->
            <div class="mx-auto w-20 h-20 rounded-full bg-primary/10 text-primary flex items-center justify-center border border-primary/20 shadow-inner">
              <svg class="animate-spin h-10 w-10 text-primary" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </div>

            <div>
              <span class="text-xs font-semibold text-primary uppercase tracking-widest">
                {lang === 'es' ? 'Verificando Transacción' : 'Verifying Transaction'}
              </span>
              <h1 class="font-display text-4xl mt-2 mb-3">
                {lang === 'es' ? 'Procesando tu Pago...' : 'Processing Payment...'}
              </h1>
              <p class="text-text-secondary-light dark:text-text-secondary-dark text-sm max-w-md mx-auto">
                {lang === 'es' 
                  ? 'Estamos esperando la confirmación de Mercado Pago. Esto tomará solo unos segundos. No cierre esta pestaña.' 
                  : 'We are waiting for Mercado Pago confirmation. This will take just a few seconds. Do not close this tab.'}
              </p>
            </div>
          </div>
        ) : (
          <!-- Expired / Failed State -->
          <div class="bg-surface-card-light dark:bg-surface-card-dark p-8 rounded-3xl border border-black/5 dark:border-white/5 shadow-2xl text-center space-y-4">
            <div class="mx-auto w-20 h-20 rounded-full bg-red-500/10 dark:bg-red-500/15 text-red-500 flex items-center justify-center border border-red-500/20 shadow-inner">
              <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </div>

            <div>
              <span class="text-xs font-semibold text-red-600 dark:text-red-400 uppercase tracking-widest">
                {lang === 'es' ? 'Reserva Expirada o Fallida' : 'Booking Expired or Failed'}
              </span>
              <h1 class="font-display text-4xl mt-2 mb-3">
                {lang === 'es' ? 'No se completó el Pago' : 'Payment Not Completed'}
              </h1>
              <p class="text-text-secondary-light dark:text-text-secondary-dark text-sm max-w-md mx-auto">
                {lang === 'es' 
                  ? 'El límite de 15 minutos para garantizar la habitación ha expirado o el pago fue rechazado. Por favor, intente nuevamente.' 
                  : 'The 15-minute window to hold the room expired or the payment failed. Please try again.'}
              </p>
            </div>
            <a
              href={lang === 'es' ? '/es/book' : '/book'}
              class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold py-3 px-6 rounded-xl transition-all duration-300 shadow-sm"
            >
              {lang === 'es' ? 'Intentar de Nuevo' : 'Try Again'}
            </a>
          </div>
        )}

        <!-- Details Receipt Card (Only show if paid or pending) -->
        {(booking.status === 'paid' || booking.status === 'pending') && (
          <div class="bg-surface-card-light dark:bg-surface-card-dark p-8 rounded-3xl border border-black/5 dark:border-white/5 shadow-lg space-y-6 print:shadow-none print:border-none print:p-0">
            <h2 class="font-display text-2xl border-b border-black/5 dark:border-white/5 pb-3">
              {lang === 'es' ? 'Detalles de la Reserva' : 'Booking Details'}
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-sm">
              <!-- Guest details -->
              <div class="space-y-1">
                <span class="text-xs uppercase font-semibold text-text-secondary-light dark:text-text-secondary-dark tracking-wider">{lang === 'es' ? 'Huésped Principal' : 'Primary Guest'}</span>
                <p class="font-bold text-text-primary-light dark:text-text-primary-dark">{booking.guestName}</p>
                {booking.guestEmail && <p class="text-text-secondary-light dark:text-text-secondary-dark">{booking.guestEmail}</p>}
                {booking.guestPhone && <p class="text-text-secondary-light dark:text-text-secondary-dark">{booking.guestPhone}</p>}
              </div>

              <!-- Stay Info -->
              <div class="space-y-1">
                <span class="text-xs uppercase font-semibold text-text-secondary-light dark:text-text-secondary-dark tracking-wider">{lang === 'es' ? 'Habitación' : 'Room Type'}</span>
                <p class="font-bold text-text-primary-light dark:text-text-primary-dark">{room.name[lang]}</p>
                <p class="text-text-secondary-light dark:text-text-secondary-dark">{booking.guests} {booking.guests === 1 ? (lang === 'es' ? 'Huésped' : 'Guest') : (lang === 'es' ? 'Huéspedes' : 'Guests')}</p>
              </div>
            </div>

            <!-- Calendar Dates Summary Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 border-t border-b border-black/5 dark:border-white/5 py-5">
              <div class="p-4 rounded-2xl bg-stone-50 dark:bg-stone-900 border border-black/5 dark:border-white/5">
                <span class="block text-[10px] uppercase font-semibold text-text-secondary-light dark:text-text-secondary-dark tracking-widest mb-1">{lang === 'es' ? 'Fecha de Entrada (Check-In)' : 'Check-In Date'}</span>
                <p class="font-semibold text-sm">{formatDate(booking.checkIn)}</p>
                <span class="text-xs text-text-secondary-light dark:text-text-secondary-dark mt-0.5 block">Desde/From 11:00 AM</span>
              </div>

              <div class="p-4 rounded-2xl bg-stone-50 dark:bg-stone-900 border border-black/5 dark:border-white/5">
                <span class="block text-[10px] uppercase font-semibold text-text-secondary-light dark:text-text-secondary-dark tracking-widest mb-1">{lang === 'es' ? 'Fecha de Salida (Check-Out)' : 'Check-Out Date'}</span>
                <p class="font-semibold text-sm">{formatDate(booking.checkOut)}</p>
                <span class="text-xs text-text-secondary-light dark:text-text-secondary-dark mt-0.5 block">Hasta/To 10:00 AM</span>
              </div>
            </div>

            <!-- Pricing summary -->
            <div class="flex items-center justify-between">
              <div class="space-y-1">
                <span class="text-xs uppercase font-semibold text-text-secondary-light dark:text-text-secondary-dark tracking-wider">{lang === 'es' ? 'Detalle de Facturación' : 'Billing Detail'}</span>
                <p class="text-text-secondary-light dark:text-text-secondary-dark">{booking.nights} {booking.nights === 1 ? (lang === 'es' ? 'noche' : 'night') : (lang === 'es' ? 'noches' : 'nights')} x ${room.pricePerNight} USD</p>
              </div>
              <div class="text-right">
                <span class="block text-xs uppercase font-semibold text-text-secondary-light dark:text-text-secondary-dark tracking-wider">{lang === 'es' ? 'Total' : 'Total'}</span>
                <p class="font-display text-3xl font-bold text-primary">${booking.totalPrice} USD</p>
              </div>
            </div>
          </div>
        )}

        <!-- Buttons Toolbar (Hidden when printing) -->
        <div class="flex flex-col sm:flex-row gap-4 justify-between items-center pt-4 print:hidden">
          <a
            href={lang === 'es' ? '/es' : '/'}
            class="text-text-secondary-light dark:text-text-secondary-dark hover:text-primary dark:hover:text-primary font-semibold text-sm transition-colors duration-200"
          >
            &larr; {lang === 'es' ? 'Volver al Inicio' : 'Return to Home'}
          </a>

          {booking.status === 'paid' && (
            <div class="flex gap-4 w-full sm:w-auto">
              <!-- Print Button -->
              <button
                type="button"
                onclick="window.print()"
                class="w-full sm:w-auto bg-stone-100 hover:bg-stone-200 dark:bg-stone-800 dark:hover:bg-stone-700 text-stone-800 dark:text-stone-200 font-semibold py-3 px-6 rounded-xl transition-all duration-200 text-sm flex items-center justify-center gap-2 cursor-pointer border border-black/5 dark:border-white/5 shadow-sm"
              >
                <span>🖨️ {lang === 'es' ? 'Imprimir Comprobante' : 'Print Receipt'}</span>
              </button>
            </div>
          )}
        </div>
      </div>
    ) : (
      <div class="bg-surface-card-light dark:bg-surface-card-dark p-12 rounded-3xl border border-black/5 dark:border-white/5 shadow-2xl text-center space-y-6 animate-fade-in">
        <div class="mx-auto w-16 h-16 rounded-full bg-red-500/10 dark:bg-red-500/15 text-red-500 flex items-center justify-center border border-red-500/20 shadow-inner">
          <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
        <div>
          <h1 class="font-display text-3xl mb-2">
            {lang === 'es' ? 'Reserva No Encontrada' : 'Booking Not Found'}
          </h1>
          <p class="text-text-secondary-light dark:text-text-secondary-dark text-sm max-w-md mx-auto">
            {lang === 'es' 
              ? 'No pudimos recuperar los detalles de esta reserva. Si acabas de realizar el pago, es posible que el sistema esté procesando la transacción.' 
              : 'We were unable to locate details for this reservation ID. If you just made the payment, the transaction might still be processing.'}
          </p>
        </div>
        <a
          href={lang === 'es' ? '/es' : '/'}
          class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold py-3 px-6 rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-primary/25 text-sm"
        >
          {lang === 'es' ? 'Volver al Inicio' : 'Return to Home'}
        </a>
      </div>
    )}
  </main>
</Layout>

<script define:vars={{ bookingId, initialStatus: booking?.status, backendUrl: BACKEND_URL }}>
  // If status is pending, poll for updates every 3 seconds
  if (bookingId && initialStatus === 'pending') {
    const pollInterval = setInterval(async () => {
      try {
        const response = await fetch(`${backendUrl}/api/booking-status?cart_id=${bookingId}`);
        if (response.ok) {
          const data = await response.json();
          if (data.success) {
            if (data.status === 'paid' || data.status === 'failed' || data.status === 'expired') {
              clearInterval(pollInterval);
              window.location.reload(); // Reload to render the new state
            }
          }
        }
      } catch (err) {
        console.error('[Polling] Error:', err);
      }
    }, 3000);
  }
</script>
