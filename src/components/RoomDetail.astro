---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import type { Room } from "../data/rooms";
import { useTranslations } from "../i18n/utils";
import SVGIcons from "./icons/SVGIcons.astro";

interface Props {
  room: Room;
  lang: "en" | "es";
}

const { room, lang } = Astro.props;
const t = useTranslations(lang);

// Dynamically import all room images and hotel fallback images
const allRoomImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/rooms/**/*.jpg",
);
const allHotelImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/hotel/**/*.jpg",
);

let roomImages: { default: ImageMetadata }[] = [];

if (room.photoCount === 0) {
  // Room has no photos, load fallback images from src/assets/hotel/
  const hotelKeys = Object.keys(allHotelImages).sort((a, b) =>
    a.localeCompare(b),
  );
  roomImages = await Promise.all(hotelKeys.map((key) => allHotelImages[key]()));
} else {
  // Load photos from specific room folder
  const roomKeys = Object.keys(allRoomImages)
    .filter((key) => key.includes(`/${room.photoFolder}/`))
    .sort((a, b) => a.localeCompare(b));
  roomImages = await Promise.all(roomKeys.map((key) => allRoomImages[key]()));
}

const images = roomImages.map((img) => img.default);

// Translate bedding info dynamically
const translatedBeds = room.beds
  .replace("single beds", lang === "es" ? "camas individuales" : "single beds")
  .replace("single bed", lang === "es" ? "cama individual" : "single bed")
  .replace("king bed", lang === "es" ? "cama king" : "king bed")
  .replace("king +", lang === "es" ? "king +" : "king +");

// Map of amenities to SVG icons and translated labels
const amenitiesMap: Record<
  string,
  {
    label: { en: string; es: string };
    iconName: "wifi" | "breakfast" | "hot-water" | "heating" | "tv" | "laundry";
  }
> = {
  wifi: {
    label: {
      en: "Free High-Speed Wi-Fi",
      es: "Wi-Fi de alta velocidad gratis",
    },
    iconName: "wifi",
  },
  breakfast: {
    label: { en: "Breakfast Included", es: "Desayuno buffet incluido" },
    iconName: "breakfast",
  },
  "hot-water": {
    label: { en: "24h Hot Water", es: "Agua caliente 24h" },
    iconName: "hot-water",
  },
  heating: {
    label: { en: "Heating System", es: "Calefacción central" },
    iconName: "heating",
  },
  tv: {
    label: { en: "Cable TV", es: "TV por cable" },
    iconName: "tv",
  },
  laundry: {
    label: { en: "Laundry Service", es: "Servicio de lavandería" },
    iconName: "laundry",
  },
};
const roomSchema = {
  "@context": "https://schema.org",
  "@type": "HotelRoom",
  name: room.name[lang],
  description: room.description[lang],
  bed: translatedBeds,
  occupancy: {
    "@type": "QuantitativeValue",
    value: room.maxGuests,
    unitText: lang === "es" ? "persona" : "person",
  },
  offers: {
    "@type": "Offer",
    price: room.pricePerNight,
    priceCurrency: "USD",
    offeredBy: {
      "@type": "Hotel",
      name: "USGAR Hotels",
      address: {
        "@type": "PostalAddress",
        streetAddress: "San Pedro",
        addressLocality: "Cusco",
        addressCountry: "PE",
      },
    },
  },
};
---

<Layout
  title={`${room.name[lang]} — USGAR Hotels`}
  lang={lang}
  schema={roomSchema}
>
  <!-- Main Container -->
  <main class="py-24 px-4 max-w-7xl mx-auto flex-1 animate-fade-in">
    <!-- Breadcrumbs & Back link -->
    <div class="mb-8 flex items-center justify-between">
      <nav
        class="flex text-sm text-[#57534E] dark:text-[#A8A29E] font-medium gap-2"
      >
        <a
          href={lang === "es" ? "/es" : "/"}
          class="hover:text-primary transition-colors"
        >
          {lang === "es" ? "Inicio" : "Home"}
        </a>
        <span>/</span>
        <span class="text-[#1C1917] dark:text-[#FAFAF9]">{room.name[lang]}</span
        >
      </nav>

      <a
        href={lang === "es" ? "/es/#rooms" : "/#rooms"}
        class="inline-flex items-center gap-2 text-primary hover:text-primary-dark font-semibold text-sm transition-colors duration-300 group"
      >
        <svg
          class="w-4 h-4 group-hover:-translate-x-1 transition-transform"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M7 16l-4-4m0 0l4-4m-4 4h18"></path>
        </svg>
        {lang === "es" ? "Volver a habitaciones" : "Back to rooms"}
      </a>
    </div>

    <!-- Title and Badge -->
    <div class="mb-10">
      <span class="text-sm font-semibold text-primary uppercase tracking-widest"
        >{t("rooms.sectionLabel")}</span
      >
      <h1 class="font-display text-4xl md:text-6xl mt-2 mb-4 leading-tight">
        {room.name[lang]}
      </h1>
      <div
        class="flex items-center gap-4 text-sm text-[#57534E] dark:text-[#A8A29E] mt-3"
      >
        <span class="flex items-center gap-1">
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
            ></path>
          </svg>
          {t("rooms.upTo")}
          {room.maxGuests}
          {lang === "es" ? "huéspedes" : "guests"}
        </span>
        <span>•</span>
        <span class="flex items-center gap-1.5">🛏️ {translatedBeds}</span>
      </div>
    </div>

    <!-- 5-Image Premium Grid Gallery -->
    <div
      class="grid grid-cols-2 md:grid-cols-4 gap-2 md:gap-3 rounded-2xl overflow-hidden shadow-lg aspect-[3/2] md:aspect-[3/1.2] mb-12"
    >
      <!-- 1st Image (Featured) - spans 2 cols, 2 rows -->
      <div
        class="col-span-2 row-span-2 relative cursor-pointer overflow-hidden group gallery-thumbnail-btn"
        data-index="0"
      >
        <Image
          src={images[0]}
          alt={`${room.name[lang]} - 1`}
          width={1200}
          height={800}
          format="webp"
          quality={85}
          loading="eager"
          fetchpriority="high"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <div
          class="absolute inset-0 bg-black/10 group-hover:bg-black/35 transition-colors duration-300"
        >
        </div>
      </div>

      <!-- 2nd Image -->
      <div
        class="col-span-1 row-span-1 relative cursor-pointer overflow-hidden group gallery-thumbnail-btn"
        data-index="1"
      >
        <Image
          src={images[1]}
          alt={`${room.name[lang]} - 2`}
          width={600}
          height={400}
          format="webp"
          quality={80}
          loading="lazy"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <div
          class="absolute inset-0 bg-black/10 group-hover:bg-black/35 transition-colors duration-300"
        >
        </div>
      </div>

      <!-- 3rd Image -->
      <div
        class="col-span-1 row-span-1 relative cursor-pointer overflow-hidden group gallery-thumbnail-btn"
        data-index="2"
      >
        <Image
          src={images[2]}
          alt={`${room.name[lang]} - 3`}
          width={600}
          height={400}
          format="webp"
          quality={80}
          loading="lazy"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <div
          class="absolute inset-0 bg-black/10 group-hover:bg-black/35 transition-colors duration-300"
        >
        </div>
      </div>

      <!-- 4th Image -->
      <div
        class="col-span-1 row-span-1 relative cursor-pointer overflow-hidden group gallery-thumbnail-btn"
        data-index="3"
      >
        <Image
          src={images[3]}
          alt={`${room.name[lang]} - 4`}
          width={600}
          height={400}
          format="webp"
          quality={80}
          loading="lazy"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <div
          class="absolute inset-0 bg-black/10 group-hover:bg-black/35 transition-colors duration-300"
        >
        </div>
      </div>

      <!-- 5th Image with "+X more" overlay -->
      <div
        class="col-span-1 row-span-1 relative cursor-pointer overflow-hidden group gallery-thumbnail-btn"
        data-index="4"
      >
        <Image
          src={images[4]}
          alt={`${room.name[lang]} - 5`}
          width={600}
          height={400}
          format="webp"
          quality={80}
          loading="lazy"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <div
          class="absolute inset-0 bg-black/20 group-hover:bg-black/40 transition-colors duration-300 flex items-center justify-center"
        >
          {
            images.length > 5 && (
              <span class="text-white text-base md:text-xl font-semibold backdrop-blur-md bg-black/45 px-4 py-2.5 rounded-xl border border-white/10 group-hover:scale-105 transition-transform duration-300 shadow-md">
                +{images.length - 5} {lang === "es" ? "fotos" : "photos"}
              </span>
            )
          }
        </div>
      </div>
    </div>

    <!-- Room Main Layout Details -->
    <div
      class="grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-16 mb-20 items-start"
    >
      <!-- Left: Description and Amenities (2 columns wide) -->
      <div class="lg:col-span-2 space-y-12 animate-on-scroll">
        <!-- Description -->
        <div>
          <h2 class="font-display text-2xl md:text-3xl mb-4">
            {lang === "es" ? "Sobre la habitación" : "About the room"}
          </h2>
          <p class="text-lg leading-relaxed text-[#57534E] dark:text-[#A8A29E]">
            {room.description[lang]}
          </p>
        </div>

        <hr class="border-black/5 dark:border-white/5" />

        <!-- Amenities -->
        <div>
          <h2 class="font-display text-2xl md:text-3xl mb-6">
            {lang === "es" ? "Servicios y comodidades" : "Amenities & Comforts"}
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {
              room.amenities.map((amenityKey) => {
                const amenity = amenitiesMap[amenityKey];
                if (!amenity) return null;
                return (
                  <div class="flex items-start gap-4 p-4 rounded-xl bg-white dark:bg-[#1C1917] border border-black/5 dark:border-white/5 shadow-sm">
                    <div class="p-2.5 rounded-lg bg-[#2DB5A0]/10 dark:bg-[#2DB5A0]/15 flex items-center justify-center">
                      <SVGIcons
                        name={amenity.iconName}
                        class="w-5 h-5 text-tertiary"
                      />
                    </div>
                    <div>
                      <h3 class="font-medium text-sm text-[#1C1917] dark:text-[#FAFAF9]">
                        {amenity.label[lang]}
                      </h3>
                      <p class="text-xs text-[#57534E] dark:text-[#A8A29E] mt-0.5">
                        {lang === "es"
                          ? "Incluido sin costo extra"
                          : "Included at no extra cost"}
                      </p>
                    </div>
                  </div>
                );
              })
            }
          </div>
        </div>
      </div>

      <!-- Right: Sticky Booking Panel (1 column wide) -->
      <div
        class="lg:col-span-1 lg:sticky lg:top-24 bg-white dark:bg-[#1C1917] p-8 rounded-2xl border border-black/5 dark:border-white/5 shadow-lg space-y-6 animate-on-scroll"
        style="transition-delay: 0.1s;"
      >
        <div>
          <span
            class="text-xs font-semibold uppercase tracking-wider text-[#A8A29E]"
            >{lang === "es" ? "Tarifa base" : "Base rate"}</span
          >
          <div class="flex items-baseline gap-1 mt-1">
            <span class="text-5xl font-bold font-display text-primary"
              >${room.pricePerNight}</span
            >
            <span class="text-sm font-medium text-[#57534E] dark:text-[#A8A29E]"
              >{t("rooms.perNight")}</span
            >
          </div>
        </div>

        <!-- Room Specs Quickbox -->
        <div
          class="border-t border-b border-black/5 dark:border-white/5 py-4 space-y-3"
        >
          <div class="flex justify-between text-sm">
            <span class="text-[#57534E] dark:text-[#A8A29E]"
              >{lang === "es" ? "Capacidad máxima" : "Max capacity"}</span
            >
            <span class="font-semibold"
              >{room.maxGuests} {lang === "es" ? "personas" : "guests"}</span
            >
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-[#57534E] dark:text-[#A8A29E]"
              >{lang === "es" ? "Distribución" : "Bed configuration"}</span
            >
            <span class="font-semibold">{translatedBeds}</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-[#57534E] dark:text-[#A8A29E]">Check-in</span>
            <span class="font-semibold">11:00 AM</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-[#57534E] dark:text-[#A8A29E]">Check-out</span>
            <span class="font-semibold">10:00 AM</span>
          </div>
        </div>

        <!-- Booking Call to Action (CTA) -->
        <a
          href={`${lang === "es" ? "/es/book" : "/book"}?roomType=${room.slug}`}
          class="block w-full text-center bg-primary hover:bg-primary-dark text-white font-semibold py-4 rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-primary/25 hover:-translate-y-0.5 text-lg cursor-pointer"
        >
          {lang === "es" ? "Reservar Habitación" : "Book this Room"}
        </a>

        <p
          class="text-[11px] text-center text-[#57534E] dark:text-[#A8A29E] leading-normal px-2"
        >
          {
            lang === "es"
              ? "Garantía de mejor tarifa disponible reservando directamente en nuestra web."
              : "Best rate guarantee when booking directly on our official website."
          }
        </p>
      </div>
    </div>

    <!-- Interactive Room Video Tour Section -->
    <section class="mb-20 animate-on-scroll">
      <div class="text-center mb-8">
        <span
          class="text-xs font-semibold text-primary uppercase tracking-widest"
          >{lang === "es" ? "Experiencia Visual" : "Visual Experience"}</span
        >
        <h2 class="font-display text-3xl md:text-4xl mt-2 mb-3">
          {lang === "es" ? "Video Tour de la Habitación" : "Room Video Tour"}
        </h2>
        <p class="text-[#57534E] dark:text-[#A8A29E] max-w-lg mx-auto text-sm">
          {
            lang === "es"
              ? "Recorre la habitación de forma interactiva y admira sus detalles antes de tu llegada."
              : "Take a virtual walkthrough of the room and appreciate the details before your stay."
          }
        </p>
      </div>

      <!-- Cinema Video Embed -->
      <div
        class="relative max-w-4xl mx-auto rounded-3xl overflow-hidden shadow-2xl bg-black border border-white/5 aspect-video group/video"
      >
        <!-- Native Video Element (preload="none" and optimized poster) -->
        <video
          id="room-tour-video"
          src={`/videos/rooms/${room.slug}.mp4`}
          preload="none"
          muted
          playsinline
          class="w-full h-full object-cover opacity-90 transition-opacity duration-300"
          style="display: block;"
        >
        </video>

        <!-- Initial Poster and Play Overlay -->
        <div
          id="video-overlay"
          class="absolute inset-0 flex flex-col items-center justify-center bg-black/40 group-hover/video:bg-black/50 transition-all duration-300 cursor-pointer"
        >
          <!-- Render dynamic poster using optimized image -->
          <div class="absolute inset-0 -z-10 w-full h-full">
            <Image
              src={images[0]}
              alt={`${room.name[lang]} video poster`}
              width={1200}
              height={800}
              format="webp"
              quality={80}
              loading="lazy"
              class="w-full h-full object-cover opacity-60"
            />
          </div>

          <!-- Play Button Ring -->
          <div
            class="w-20 h-20 rounded-full border-2 border-white/80 bg-black/25 backdrop-blur-sm flex items-center justify-center text-white scale-90 group-hover/video:scale-100 transition-all duration-300 group-hover/video:border-secondary shadow-lg"
          >
            <svg
              class="w-8 h-8 fill-current ml-1 text-white group-hover/video:text-secondary transition-colors"
              viewBox="0 0 24 24"
            >
              <path d="M8 5v14l11-7z"></path>
            </svg>
          </div>
          <span
            class="text-white text-sm font-semibold tracking-wider mt-4 uppercase drop-shadow-md"
          >
            {lang === "es" ? "Iniciar Video Tour" : "Start Video Tour"}
          </span>
        </div>

        <!-- Custom Controls Overlay (Hidden when not playing) -->
        <div
          id="video-controls"
          class="absolute bottom-0 inset-x-0 p-4 bg-gradient-to-t from-black/80 via-black/40 to-transparent flex items-center justify-between opacity-0 translate-y-2 transition-all duration-300 z-10 pointer-events-none"
        >
          <div class="flex items-center gap-4 pointer-events-auto">
            <!-- Play/Pause toggle -->
            <button
              id="video-play-btn"
              class="text-white hover:text-secondary transition-colors duration-200 cursor-pointer"
              aria-label="Play or pause"
            >
              <!-- Pause icon -->
              <svg
                id="pause-icon"
                class="w-6 h-6 hidden"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"></path>
              </svg>
              <!-- Play icon -->
              <svg
                id="play-icon"
                class="w-6 h-6"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path d="M8 5v14l11-7z"></path>
              </svg>
            </button>
          </div>

          <div class="flex items-center gap-4 pointer-events-auto">
            <!-- Mute/Unmute audio -->
            <button
              id="video-audio-btn"
              class="flex items-center gap-1.5 bg-black/40 hover:bg-black/60 px-3 py-1.5 rounded-full border border-white/10 text-white text-xs transition-all duration-200 cursor-pointer"
              aria-label="Toggle audio"
            >
              <!-- Muted icon -->
              <svg
                id="video-muted-icon"
                class="w-4 h-4 text-white"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"></path>
              </svg>
              <!-- Unmuted icon -->
              <svg
                id="video-unmuted-icon"
                class="w-4 h-4 text-white hidden"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"
                ></path>
              </svg>
              <span id="audio-btn-label"
                >{lang === "es" ? "Sin sonido" : "No sound"}</span
              >
            </button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Premium Fullscreen Lightbox Element -->
  <div
    id="gallery-lightbox"
    class="fixed inset-0 z-50 bg-black/95 backdrop-blur-md hidden flex-col items-center justify-center select-none"
    role="dialog"
    aria-modal="true"
  >
    <!-- Top toolbar -->
    <div
      class="absolute top-0 inset-x-0 p-5 flex items-center justify-between z-50 bg-gradient-to-b from-black/60 to-transparent"
    >
      <!-- Index Counter -->
      <span
        id="lightbox-counter"
        class="text-white/80 text-sm font-semibold tracking-wider font-body"
        >1 / 1</span
      >

      <!-- Close Button -->
      <button
        id="lightbox-close-btn"
        class="w-11 h-11 rounded-full bg-white/5 hover:bg-white/15 text-white hover:text-secondary flex items-center justify-center transition-all duration-300 cursor-pointer border border-white/5 focus:outline-none"
        aria-label="Close gallery"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Slides Container -->
    <div
      class="relative w-full max-w-6xl max-h-[85vh] flex items-center justify-center px-6 md:px-24"
    >
      {
        images.map((img, idx) => (
          <div
            class="lightbox-slide hidden w-full h-full flex items-center justify-center"
            data-slide-index={idx}
          >
            <Image
              src={img}
              alt={`${room.name[lang]} - Lightbox Photo ${idx + 1}`}
              width={1600}
              height={1066}
              format="webp"
              quality={85}
              loading="lazy"
              class="max-w-full max-h-[80vh] object-contain rounded-lg shadow-2xl transition-all duration-300"
            />
          </div>
        ))
      }
    </div>

    <!-- Navigation Arrows -->
    <!-- Prev Arrow -->
    <button
      id="lightbox-prev-btn"
      class="absolute left-4 md:left-8 top-1/2 -translate-y-1/2 w-12 h-12 md:w-14 md:h-14 rounded-full bg-white/5 hover:bg-white/15 text-white hover:text-secondary flex items-center justify-center transition-all duration-300 cursor-pointer border border-white/5 focus:outline-none"
      aria-label="Previous slide"
    >
      <svg
        class="w-6 h-6 md:w-8 md:h-8"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"
        ></path>
      </svg>
    </button>

    <!-- Next Arrow -->
    <button
      id="lightbox-next-btn"
      class="absolute right-4 md:right-8 top-1/2 -translate-y-1/2 w-12 h-12 md:w-14 md:h-14 rounded-full bg-white/5 hover:bg-white/15 text-white hover:text-secondary flex items-center justify-center transition-all duration-300 cursor-pointer border border-white/5 focus:outline-none"
      aria-label="Next slide"
    >
      <svg
        class="w-6 h-6 md:w-8 md:h-8"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
        ></path>
      </svg>
    </button>
  </div>
</Layout>

<script>
  // Initialize component interactive elements
  function initRoomDetail() {
    // ==========================================
    // LIGHTBOX INTERACTION
    // ==========================================
    const thumbnails = document.querySelectorAll(".gallery-thumbnail-btn");
    const lightbox = document.getElementById("gallery-lightbox");
    const closeBtn = document.getElementById("lightbox-close-btn");
    const prevBtn = document.getElementById("lightbox-prev-btn");
    const nextBtn = document.getElementById("lightbox-next-btn");
    const counter = document.getElementById("lightbox-counter");
    const slides = document.querySelectorAll(".lightbox-slide");

    if (!lightbox || slides.length === 0) return;

    let activeIndex = 0;
    const totalSlides = slides.length;

    function updateLightbox() {
      slides.forEach((slide) => slide.classList.add("hidden"));
      const activeSlide = document.querySelector(
        `.lightbox-slide[data-slide-index="${activeIndex}"]`,
      );
      if (activeSlide) activeSlide.classList.remove("hidden");

      if (counter) {
        counter.textContent = `${activeIndex + 1} / ${totalSlides}`;
      }
    }

    function openLightbox(index: number) {
      if (!lightbox) return;
      activeIndex = index;
      updateLightbox();
      lightbox.classList.remove("hidden");
      lightbox.classList.add("flex");
      document.body.style.overflow = "hidden"; // prevent scroll
    }

    function closeLightbox() {
      if (!lightbox) return;
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      document.body.style.overflow = ""; // restore scroll
    }

    function nextSlide() {
      activeIndex = (activeIndex + 1) % totalSlides;
      updateLightbox();
    }

    function prevSlide() {
      activeIndex = (activeIndex - 1 + totalSlides) % totalSlides;
      updateLightbox();
    }

    // Attach click listeners to thumbnails
    thumbnails.forEach((thumb) => {
      // Replace with clean listener
      const newThumb = thumb.cloneNode(true) as HTMLElement;
      thumb.parentNode?.replaceChild(newThumb, thumb);
      newThumb.addEventListener("click", () => {
        const indexStr = newThumb.getAttribute("data-index");
        if (indexStr) openLightbox(parseInt(indexStr, 10));
      });
    });

    // Reset listener attachments
    closeBtn?.replaceWith(closeBtn.cloneNode(true));
    const newCloseBtn = document.getElementById("lightbox-close-btn");
    newCloseBtn?.addEventListener("click", closeLightbox);

    nextBtn?.replaceWith(nextBtn.cloneNode(true));
    const newNextBtn = document.getElementById("lightbox-next-btn");
    newNextBtn?.addEventListener("click", nextSlide);

    prevBtn?.replaceWith(prevBtn.cloneNode(true));
    const newPrevBtn = document.getElementById("lightbox-prev-btn");
    newPrevBtn?.addEventListener("click", prevSlide);

    // Keyboard controls
    const keyHandler = (e: KeyboardEvent) => {
      if (!lightbox || lightbox.classList.contains("hidden")) return;

      if (e.key === "Escape") closeLightbox();
      else if (e.key === "ArrowRight") nextSlide();
      else if (e.key === "ArrowLeft") prevSlide();
    };

    if ((window as any)._roomDetailKeyHandler) {
      document.removeEventListener(
        "keydown",
        (window as any)._roomDetailKeyHandler,
      );
    }
    (window as any)._roomDetailKeyHandler = keyHandler;
    document.addEventListener("keydown", keyHandler);

    // ==========================================
    // LAZY VIDEO PLAYER INTERACTION
    // ==========================================
    const video = document.getElementById(
      "room-tour-video",
    ) as HTMLVideoElement | null;
    if (!video || video.dataset.listenerAttached === "true") return;
    video.dataset.listenerAttached = "true";

    const overlay = document.getElementById("video-overlay");
    const controls = document.getElementById("video-controls");
    const playBtn = document.getElementById("video-play-btn");
    const playIcon = document.getElementById("play-icon");
    const pauseIcon = document.getElementById("pause-icon");
    const audioBtn = document.getElementById("video-audio-btn");
    const mutedIcon = document.getElementById("video-muted-icon");
    const unmutedIcon = document.getElementById("video-unmuted-icon");
    const audioLabel = document.getElementById("audio-btn-label");

    function playVideo() {
      if (!video) return;
      video.load(); // triggers download on click (preload="none")
      video
        .play()
        .then(() => {
          overlay?.classList.add("hidden");
          controls?.classList.remove(
            "opacity-0",
            "translate-y-2",
            "pointer-events-none",
          );
          controls?.classList.add("opacity-100", "translate-y-0");
          playIcon?.classList.add("hidden");
          pauseIcon?.classList.remove("hidden");
        })
        .catch((err) => {
          console.error("Error playing video:", err);
        });
    }

    function togglePlay() {
      if (!video) return;
      if (video.paused) {
        video.play().catch((e) => {});
        playIcon?.classList.add("hidden");
        pauseIcon?.classList.remove("hidden");
      } else {
        video.pause();
        playIcon?.classList.remove("hidden");
        pauseIcon?.classList.add("hidden");
      }
    }

    function toggleAudio() {
      if (!video) return;
      video.muted = !video.muted;
      const isMuted = video.muted;

      mutedIcon?.classList.toggle("hidden", !isMuted);
      unmutedIcon?.classList.toggle("hidden", isMuted);

      if (audioLabel) {
        const langCode = document.documentElement.lang || "en";
        if (isMuted) {
          audioLabel.textContent =
            langCode === "es" ? "Sin sonido" : "No sound";
        } else {
          audioLabel.textContent =
            langCode === "es" ? "Sonido activo" : "Sound active";
        }
      }
    }

    // Attach listeners directly without cloning to avoid stale element references
    overlay?.addEventListener("click", playVideo);
    playBtn?.addEventListener("click", togglePlay);
    audioBtn?.addEventListener("click", toggleAudio);
    video.addEventListener("click", togglePlay);

    // Save cleanup references to window to avoid double register on View Transitions
    (window as any)._roomDetailCleanup = () => {
      document.removeEventListener("keydown", keyHandler);
    };
  }

  // Initial load
  initRoomDetail();
  // View transitions lifecycle
  document.addEventListener("astro:after-swap", () => {
    // Call cleanup from previous page if exists
    if (typeof (window as any)._roomDetailCleanup === "function") {
      (window as any)._roomDetailCleanup();
    }
    initRoomDetail();
  });
</script>
