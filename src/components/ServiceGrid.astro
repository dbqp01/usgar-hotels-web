---
import { services } from '../data/services';
import { useTranslations } from '../i18n/utils';
import SVGIcons from './icons/SVGIcons.astro';

const lang = (Astro.currentLocale || 'en') as 'en' | 'es';
const t = useTranslations(lang);

// Grouping services for a more premium visual layout
const categories = [
  {
    title: {
      en: 'Essential Comforts',
      es: 'Comodidad Esencial'
    },
    desc: {
      en: 'Primary amenities ensuring a warm, seamless stay.',
      es: 'Comodidades principales que aseguran una estadía cálida y sin problemas.'
    },
    serviceIds: ['wifi', 'heating', 'hot-water', 'parking']
  },
  {
    title: {
      en: 'Wellness & Dining',
      es: 'Bienestar y Sabores'
    },
    desc: {
      en: 'Indulge in authentic local tastes and relaxing therapies.',
      es: 'Disfruta de sabores locales auténticos y terapias relajantes.'
    },
    serviceIds: ['breakfast', 'restaurant', 'spa', 'tv']
  },
  {
    title: {
      en: 'Travel & Experience',
      es: 'Viajes y Asistencia'
    },
    desc: {
      en: 'Everything you need to discover Cusco and Machu Picchu safely.',
      es: 'Todo lo necesario para descubrir Cusco y Machu Picchu con seguridad.'
    },
    serviceIds: ['transfer', 'tours', 'laundry']
  }
];
---

<section id="services" class="py-24 px-4 bg-stone-50 dark:bg-stone-900/10 border-t border-b border-black/5 dark:border-white/5">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16 animate-on-scroll">
      <span class="text-sm font-semibold text-primary uppercase tracking-widest">{t('services.sectionLabel')}</span>
      <h2 class="font-display text-4xl md:text-5xl mt-3 mb-4">
        {t('services.title')}
      </h2>
      <p class="text-lg text-[#57534E] dark:text-[#A8A29E] max-w-2xl mx-auto font-body font-light">
        {t('services.description')}
      </p>
    </div>

    <!-- Redesigned Grouped Services Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
      {categories.map((cat, i) => (
        <div 
          class="animate-on-scroll bg-white dark:bg-[#1C1917] p-8 rounded-3xl border border-black/5 dark:border-white/5 shadow-sm hover:shadow-md hover:border-primary/10 transition-all duration-500 flex flex-col h-full group/category"
          style={`transition-delay: ${i * 0.15}s`}
        >
          <!-- Category Header -->
          <div class="mb-6 pb-4 border-b border-black/5 dark:border-white/5">
            <span class="inline-block px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-primary/10 text-primary border border-primary/20 mb-3 group-hover/category:bg-primary group-hover/category:text-white transition-colors duration-300">
              {cat.title[lang]}
            </span>
            <p class="text-xs text-[#57534E] dark:text-[#A8A29E] font-body leading-relaxed mt-1">
              {cat.desc[lang]}
            </p>
          </div>

          <!-- Service List inside Category -->
          <div class="space-y-4 flex-1">
            {cat.serviceIds.map((sId) => {
              const service = services.find(s => s.id === sId);
              if (!service) return null;
              
              return (
                <div 
                  class="flex items-start gap-4 p-4 rounded-2xl bg-stone-50/50 dark:bg-stone-900/40 border border-black/5 dark:border-white/5 hover:border-tertiary/20 hover:bg-stone-50 dark:hover:bg-stone-900/70 transition-all duration-300 group/item hover:scale-[1.01]"
                >
                  <!-- Premium Icon Box -->
                  <div class="w-10 h-10 rounded-xl bg-white dark:bg-[#1C1917] border border-black/5 dark:border-white/5 flex items-center justify-center text-lg shadow-sm group-hover/item:border-tertiary/30 group-hover/item:text-tertiary transition-all duration-300 flex-shrink-0">
                    <SVGIcons name={service.id as any} class="w-5 h-5 text-primary group-hover/item:text-tertiary group-hover/item:scale-110 transition-transform duration-300" />
                  </div>
                  
                  <!-- Text -->
                  <div>
                    <h4 class="font-semibold text-sm text-[#1C1917] dark:text-[#FAFAF9] group-hover/item:text-tertiary transition-colors">
                      {service.name[lang]}
                    </h4>
                    <p class="text-xs text-[#57534E] dark:text-[#A8A29E] leading-relaxed mt-1 font-body font-light">
                      {service.description[lang]}
                    </p>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
