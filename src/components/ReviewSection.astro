---
import { useTranslations } from '../i18n/utils';

const lang = (Astro.currentLocale || 'en') as 'en' | 'es';
const t = useTranslations(lang);

// Mock reviews based on real TripAdvisor-style reviews
const reviews = [
  {
    id: 1,
    name: 'Sarah M.',
    country: '🇺🇸',
    rating: 5,
    text: {
      en: 'Absolutely magical! The murals and Andean decor made us feel immersed in local culture. Breakfast was incredible and the staff went above and beyond.',
      es: '¡Absolutamente mágico! Los murales y la decoración andina nos hicieron sentir sumergidos en la cultura local. El desayuno fue increíble y el personal fue excepcional.'
    },
    date: { en: 'March 2025', es: 'Marzo 2025' },
  },
  {
    id: 2,
    name: 'Thomas K.',
    country: '🇩🇪',
    rating: 5,
    text: {
      en: 'Perfect location near San Pedro Market. The rooms are warm and cozy — essential for cold Cusco nights. Will definitely return!',
      es: 'Ubicación perfecta cerca del Mercado de San Pedro. Las habitaciones son cálidas y acogedoras, algo esencial para las frías noches de Cusco. ¡Definitivamente volveré!'
    },
    date: { en: 'February 2025', es: 'Febrero 2025' },
  },
  {
    id: 3,
    name: 'Ana L.',
    country: '🇧🇷',
    rating: 5,
    text: {
      en: 'The airport transfer service was a lifesaver. Hotel is charming, clean, and the staff speaks English fluently. Great value for money.',
      es: 'El servicio de traslado al aeropuerto fue un salvavidas. El hotel es encantador, limpio y el personal habla inglés con fluidez. Gran relación calidad-precio.'
    },
    date: { en: 'January 2025', es: 'Enero 2025' },
  },
  {
    id: 4,
    name: 'James P.',
    country: '🇬🇧',
    rating: 4,
    text: {
      en: 'Lovely boutique hotel with character. The spa massage after a long day of hiking was exactly what we needed. Highly recommended!',
      es: 'Hermoso hotel boutique con carácter. El masaje de spa después de un largo día de caminata fue exactamente lo que necesitábamos. ¡Altamente recomendado!'
    },
    date: { en: 'December 2024', es: 'Diciembre 2024' },
  },
  {
    id: 5,
    name: 'Yuki T.',
    country: '🇯🇵',
    rating: 5,
    text: {
      en: 'Beautiful hotel with authentic Cusco charm. They helped us arrange our Machu Picchu tour and it was seamless. The breakfast is fresh and delicious.',
      es: 'Hermoso hotel con encanto auténtico de Cusco. Nos ayudaron a organizar nuestro tour a Machu Picchu y todo fue perfecto. El desayuno es fresco y delicioso.'
    },
    date: { en: 'November 2024', es: 'Noviembre 2024' },
  },
];
---

<section class="py-20 px-4 bg-gradient-to-b from-transparent via-primary/5 to-transparent">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-14 animate-on-scroll">
      <span class="text-sm font-semibold text-primary uppercase tracking-widest">{t('reviews.sectionLabel')}</span>
      <h2 class="font-display text-4xl md:text-5xl mt-3 mb-4">
        {t('reviews.title')}
      </h2>
      <p class="text-lg text-[#57534E] dark:text-[#A8A29E] max-w-2xl mx-auto">
        {t('reviews.description')}
      </p>
    </div>

    <!-- Reviews Carousel Container -->
    <div class="relative max-w-5xl mx-auto group/carousel" id="reviews-carousel">
      
      <!-- Left Arrow -->
      <button
        id="reviews-prev"
        class="absolute -left-4 md:-left-12 top-1/2 -translate-y-1/2 z-20 w-10 h-10 rounded-full bg-white/80 dark:bg-[#1C1917]/80 backdrop-blur-sm border border-black/5 dark:border-white/5 flex items-center justify-center text-[#1C1917] dark:text-[#FAFAF9] hover:text-primary dark:hover:text-primary hover:scale-105 shadow-md transition-all duration-300 opacity-0 group-hover/carousel:opacity-100 focus:opacity-100 disabled:opacity-30 disabled:cursor-not-allowed pointer-events-auto"
        aria-label="Previous reviews"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <!-- Right Arrow -->
      <button
        id="reviews-next"
        class="absolute -right-4 md:-right-12 top-1/2 -translate-y-1/2 z-20 w-10 h-10 rounded-full bg-white/80 dark:bg-[#1C1917]/80 backdrop-blur-sm border border-black/5 dark:border-white/5 flex items-center justify-center text-[#1C1917] dark:text-[#FAFAF9] hover:text-primary dark:hover:text-primary hover:scale-105 shadow-md transition-all duration-300 opacity-0 group-hover/carousel:opacity-100 focus:opacity-100 disabled:opacity-30 disabled:cursor-not-allowed pointer-events-auto"
        aria-label="Next reviews"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>

      <!-- Track -->
      <div class="flex gap-6 overflow-x-auto snap-x snap-mandatory pb-4 scrollbar-hide" id="reviews-track">
        {reviews.map((review, i) => (
          <div
            class="flex-shrink-0 w-80 sm:w-[420px] snap-center animate-on-scroll stagger-child"
            style={`transition-delay: ${i * 0.1}s`}
          >
            <div class="h-full p-6 rounded-2xl bg-white dark:bg-[#1C1917] border border-black/5 dark:border-white/5 shadow-sm hover:shadow-md transition-all duration-300 flex flex-col justify-between">
              <div>
                <!-- Stars -->
                <div class="flex gap-0.5 mb-4">
                  {Array.from({ length: review.rating }).map(() => (
                    <svg class="w-4 h-4 text-secondary" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>

                <!-- Quote -->
                <blockquote class="text-sm md:text-base leading-relaxed text-[#57534E] dark:text-[#A8A29E] mb-6 italic">
                  "{review.text[lang]}"
                </blockquote>
              </div>

              <!-- Author -->
              <div class="flex items-center gap-3 pt-4 border-t border-black/5 dark:border-white/5">
                <span class="text-2xl" role="img" aria-label="country flag">{review.country}</span>
                <div>
                  <p class="font-semibold text-sm text-[#1C1917] dark:text-[#FAFAF9]">{review.name}</p>
                  <p class="text-xs text-[#A8A29E]">{review.date[lang]}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Scroll indicators / Dots -->
      <div class="flex justify-center gap-2 mt-6">
        {reviews.map((_, i) => (
          <button
            class="w-2.5 h-2.5 rounded-full bg-primary/20 hover:bg-primary transition-all duration-300 cursor-pointer"
            aria-label={`Go to review ${i + 1}`}
            data-review-dot={i}
          />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  function initReviewsCarousel() {
    const track = document.getElementById('reviews-track');
    const dots = document.querySelectorAll('[data-review-dot]');
    const prevBtn = document.getElementById('reviews-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('reviews-next') as HTMLButtonElement;

    if (!track || dots.length === 0) return;

    const cards = track.children;

    // Helper to update visual states of dots & arrows
    function updateState() {
      if (!track) return;
      const trackRect = track.getBoundingClientRect();
      let minDiff = Infinity;
      let activeIndex = 0;

      for (let i = 0; i < cards.length; i++) {
        const cardRect = cards[i].getBoundingClientRect();
        // Calculate difference between card left and track left plus some padding
        const diff = Math.abs(cardRect.left - trackRect.left);
        if (diff < minDiff) {
          minDiff = diff;
          activeIndex = i;
        }
      }

      // Update dots styles
      dots.forEach((dot, idx) => {
        if (idx === activeIndex) {
          dot.classList.remove('bg-primary/20', 'w-2.5');
          dot.classList.add('bg-primary', 'w-6');
        } else {
          dot.classList.remove('bg-primary', 'w-6');
          dot.classList.add('bg-primary/20', 'w-2.5');
        }
      });

      // Update arrow disabled states
      if (prevBtn) prevBtn.disabled = track.scrollLeft <= 10;
      if (nextBtn) {
        nextBtn.disabled = Math.ceil(track.scrollLeft + track.clientWidth) >= track.scrollWidth - 10;
      }
    }

    // Scroll listener with requestAnimationFrame throttling
    let isScrolling = false;
    track.addEventListener('scroll', () => {
      if (!isScrolling) {
        window.requestAnimationFrame(() => {
          updateState();
          isScrolling = false;
        });
        isScrolling = true;
      }
    }, { passive: true });

    // Click on dots
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        const targetCard = cards[index] as HTMLElement;
        if (targetCard && track) {
          track.scrollTo({
            left: targetCard.offsetLeft - track.offsetLeft,
            behavior: 'smooth'
          });
        }
      });
    });

    // Arrow navigation clicks
    if (prevBtn && nextBtn) {
      prevBtn.addEventListener('click', () => {
        const firstCard = cards[0] as HTMLElement;
        if (firstCard && track) {
          track.scrollBy({
            left: -firstCard.offsetWidth - 24, // width + gap
            behavior: 'smooth'
          });
        }
      });

      nextBtn.addEventListener('click', () => {
        const firstCard = cards[0] as HTMLElement;
        if (firstCard && track) {
          track.scrollBy({
            left: firstCard.offsetWidth + 24, // width + gap
            behavior: 'smooth'
          });
        }
      });
    }

    // Run initial state setup
    updateState();
  }

  // Run on initial load
  initReviewsCarousel();

  // Run after Astro View Transitions page swaps
  document.addEventListener('astro:after-swap', initReviewsCarousel);
</script>
